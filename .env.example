# ─────────────────────────────────────────────────────────────────────────────
# EPL — local development environment
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Used only by `docker compose up`. For local `dotnet run` against a local
# SQL Server, use `dotnet user-secrets` instead (see SECRETS.md).
# ─────────────────────────────────────────────────────────────────────────────

# SQL Server (docker-compose only).
# Must satisfy SQL Server's complexity rules: 8+ chars, upper, lower, digit,
# and at least one non-alphanumeric character.
MSSQL_SA_PASSWORD=ChangeMe_Dev_Passw0rd!

# Bootstrap admin user — seeded into AspNetUsers on first run.
# Sign in to the web app with these credentials on a fresh DB.
BOOTSTRAP_ADMIN_EMAIL=admin@epl.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Admin_Passw0rd!

# Frontend backend mode (default true — runs the seeded local API)
USE_STUBBED_BACKEND=true
STUBBED_BACKEND_API_URL=http://localhost:8080/api
ACTUAL_BACKEND_API_URL=
