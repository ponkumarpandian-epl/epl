# Copy this file to `.env` (gitignored) and fill in the password before running
# the suite. The .env values mirror what's in `dotnet user-secrets list` for the
# API project — same bootstrap admin account, just exposed to the test harness.
#
# DO NOT commit the actual .env. The repo's secret-scan (verify.yml) will reject
# any PR that contains the literal admin password, and .env is gitignored
# precisely to prevent that.

BASE_URL=http://localhost:3000

E2E_ADMIN_EMAIL=admin@epl.local
E2E_ADMIN_PASSWORD=__paste-from-dotnet-user-secrets__
